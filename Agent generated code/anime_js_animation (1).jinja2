{# [V0.A7] Anime.js export #}
import anime from "animejs";

export function play{{ component_name }}() {
{% for layer in layers %}  anime({
    targets: "#{{ layer.class_name }}",
    translateX: [{% for s in layer.steps %}{{ s.x }}{{ ", " if not loop.last }}{% endfor %}],
    translateY: [{% for s in layer.steps %}{{ s.y }}{{ ", " if not loop.last }}{% endfor %}],
    scale: [{% for s in layer.steps %}{{ s.scaleX }}{{ ", " if not loop.last }}{% endfor %}],
    rotate: [{% for s in layer.steps %}"{{ s.rotation }}deg"{{ ", " if not loop.last }}{% endfor %}],
    opacity: [{% for s in layer.steps %}{{ s.opacity }}{{ ", " if not loop.last }}{% endfor %}],
    duration: {{ duration_ms }},
    easing: "{{ anime_easing }}",
    loop: {{ "true" if loop else "false" }},
  });
{% endfor %}}
