{# [V0.A7] GSAP timeline export #}
import { gsap } from "gsap";

export function play{{ component_name }}(root{{ ": HTMLElement" if typescript }} = document.body) {
  const tl = gsap.timeline({ repeat: {{ "-1" if loop else "0" }}, defaults: { ease: "{{ gsap_easing }}" } });

{% for layer in layers %}  // {{ layer.name }}
  gsap.set(root.querySelector("#{{ layer.class_name }}"), {
    x: {{ layer.steps[0].x }}, y: {{ layer.steps[0].y }},
    scaleX: {{ layer.steps[0].scaleX }}, scaleY: {{ layer.steps[0].scaleY }},
    rotation: {{ layer.steps[0].rotation }}, opacity: {{ layer.steps[0].opacity }},
  });
{% for step in layer.steps[1:] %}  tl.to("#{{ layer.class_name }}", {
    x: {{ step.x }}, y: {{ step.y }}, scaleX: {{ step.scaleX }}, scaleY: {{ step.scaleY }},
    rotation: {{ step.rotation }}, opacity: {{ step.opacity }}, duration: {{ step.segment_duration_s }},
  }, {{ step.absolute_time_s }});
{% endfor %}
{% endfor %}
  return tl;
}
