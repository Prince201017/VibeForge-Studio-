{# [V0.A7] Framer Motion React component export.
   Every style/initial/animate/transition prop below is a single flat
   `{{ layer.whatever_str }}` substitution — the value already contains its
   own literal `{ ... }` braces, computed in code_export.py::_layer_view.
   This avoids nesting `{{ }}` Jinja expressions inside JSX's own `{{ }}`
   double-brace object syntax, which Jinja can't parse (see code_export.py
   header comment for why). #}
import { motion } from "framer-motion";
{% if typescript %}
interface {{ component_name }}Props {
  className?: string;
}
{% endif %}

export default function {{ component_name }}({{ "{ className }: " ~ component_name ~ "Props" if typescript else "{ className }" }}) {
  return (
    <div className={className} style={{ stage_style_str }}>
{% for layer in layers %}      <motion.div
        style={{ layer.style_str }}
        initial={{ layer.initial_str }}
        animate={{ layer.animate_str }}
        transition={{ transition_str }}
      />
{% endfor %}    </div>
  );
}
