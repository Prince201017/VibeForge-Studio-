<!DOCTYPE html>
{# [V0.A7] Standalone HTML export - embeds the generated CSS animation #}
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  {% if css_scope == "inline" %}
  <style>
    body { margin: 0; background: {{ background or "transparent" }}; overflow: hidden; }
    .stage { position: relative; width: {{ width }}px; height: {{ height }}px; margin: 0 auto; }
{{ css_body | indent(4, first=True) }}
  </style>
  {% else %}
  <link rel="stylesheet" href="./animation.css" />
  {% endif %}
</head>
<body>
  <main class="stage" role="img" aria-label="{{ title }} animation">
{% for layer in layers %}    <div class="{{ layer.class_name }}" aria-hidden="true"></div>
{% endfor %}  </main>
</body>
</html>
